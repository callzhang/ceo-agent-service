{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WechatMemoryCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["statement", "category", "confidence", "sensitivity", "source_message_ids", "evidence_excerpt", "cleanup_notes"],
  "properties": {
    "statement": {"type": "string", "minLength": 1},
    "category": {"type": "string", "enum": ["fact", "preference", "commitment", "decision", "project_status", "relationship", "reusable_experience"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "sensitivity": {"type": "string", "enum": ["normal", "sensitive", "high"]},
    "source_message_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "source_conversation_ids": {"type": "array", "items": {"type": "string"}},
    "source_time_start": {"type": "string"},
    "source_time_end": {"type": "string"},
    "evidence_excerpt": {"type": "string"},
    "cleanup_notes": {"type": "string"}
  }
}
