<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.stardust.ceo-agent.wechat-reader</string>
  <key>ProgramArguments</key>
  <array>
    <string>__READER_EXECUTABLE__</string>
    <string>serve</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
  <key>LimitLoadToSessionType</key>
  <string>Aqua</string>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/ceo-agent-service/wechat-reader.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/ceo-agent-service/wechat-reader.stderr.log</string>
</dict>
</plist>
