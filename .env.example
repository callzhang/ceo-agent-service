# Local knowledge workspace. This directory is read by Codex and graphify.
CEO_WORKSPACE=$HOME/Documents/memory

# Local runtime state. Keep this file out of Git.
CEO_WORKER_DB=./data/auto-reply.sqlite3

# Dry-run is the safe default. Set CEO_DRY_RUN=0 only after reviewing behavior.
CEO_DRY_RUN=1

# Fast path routing.
CEO_PRODUCER_INTERVAL_SECONDS=60
CEO_CONSUMER_POLL_INTERVAL_SECONDS=10
CEO_POLL_INTERVAL_SECONDS=30
CEO_BATCH_SECONDS=120
CEO_CORPUS_DIR=./data/corpus
CEO_WORK_PROFILE_PATH=./data/work-profile/work_profile.md
CEO_DEVELOPER_PROMPT_TEMPLATE_PATH=./data/prompts/developer_prompt.md
CEO_USER_PROMPT_TEMPLATE_PATH=./data/prompts/user_prompt.md
CEO_DWS_TRANSIENT_RETRY_ATTEMPTS=3
CEO_DWS_TRANSIENT_RETRY_DELAY_SECONDS=1.0
CEO_TASK_WORK_ITEM_INTERVAL_SECONDS=60
CEO_TASK_DAILY_INTERVAL_SECONDS=86400

# OKR review live source. Default is dingteam_web and requires an explicit
# command that returns live 叮当OKR JSON. Prefer the dingtang-okr-review
# browser source with its dedicated token cache; run its one-time login flow
# when the cache expires. Use agoal only when this tenant's OKR data is
# actually exposed through Agoal objective APIs.
CEO_OKR_SOURCE_KIND=dingteam_web
CEO_OKR_OBJECTIVE_RULE_ID=
CEO_OKR_LIVE_SOURCE_COMMAND=/Users/derek/.agents/skills/dingtang-okr-review/scripts/dingteam_okr_browser_source.py fetch --user-id {user_id} --period-label {period_label}

# Producer recovery routing. Fast path still runs every producer interval; these
# values control the slower fallback scans that protect against missed messages.
MESSAGE_RECOVERY_INTERVAL=5m
SINGLE_CHAT_READ_RECOVERY_WINDOW=24h
SINGLE_CHAT_READ_RECOVERY_LIMIT=50
GROUP_READ_RECOVERY_WINDOW=24h
GROUP_READ_RECOVERY_LIMIT=3

# Principal/persona configuration.
CEO_PRINCIPAL_NAME=Executive
USER_ALIAS=Executive
CEO_MENTION_ALIASES=@CEO,@Executive
DOCUMENT_EXTRACTION_IDS=Executive
CEO_ASSISTANT_SIGNATURE="(via agent)"
CEO_HANDOFF_ACK="I will ask Executive to take a look. (via agent)"
CEO_FORBIDDEN_PATH_PREFIXES=$HOME/

# Counterparty feedback links. Leave empty to disable.
CEO_FEEDBACK_SPIKE_VERCEL_BASE_URL=

# Prompt user variables. These fill <var: ...> tags in prompt templates.
# Identity variables such as principal/handoff_name are derived from the
# system config above instead of being duplicated here.
CEO_PROMPT_VAR_RESPONSIBILITY_SUMMARY="Reply only when the message clearly requires the principal's decision or responsibility."
CEO_PROMPT_VAR_FORBIDDEN_REPLY_TEXT_TERMS=
CEO_PROMPT_VAR_OA_APPROVAL_RULES=management/OA/钉钉审批审阅原则.md
CEO_PROMPT_VAR_CALENDAR_RULES_PATH=management/OA/日历规则.md

# Optional handoff notification settings.
CEO_DING_ROBOT_CODE=
CEO_DING_ROBOT_NAME=
CEO_DING_RECEIVER_USER_ID=

# Required explicit opt-in for live sends.
CEO_LIVE_SEND_BLOCKERS_ACCEPTED=
